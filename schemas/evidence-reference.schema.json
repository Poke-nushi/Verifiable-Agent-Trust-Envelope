{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:evidence-reference:0.3",
  "title": "VATE Evidence Reference",
  "description": "Draft v0.3 evidence reference and verification result object for admission receipts.",
  "type": "object",
  "required": [
    "type",
    "uri",
    "digest",
    "verification"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "agent_card",
        "signed_agent_card",
        "oauth_access_token",
        "oauth_transaction_token",
        "openid_subject",
        "oid4vp_presentation",
        "verifiable_credential",
        "vc_status",
        "did_document",
        "web_bot_auth_signature",
        "http_message_signature",
        "mission_permit",
        "payment_mandate",
        "payment_required_state",
        "delegated_payment_token",
        "payment_authority",
        "runtime_attestation",
        "runtime_disclosure",
        "status_bundle",
        "admission_request",
        "admission_receipt",
        "post_execution_receipt",
        "policy_snapshot",
        "attenuation_candidate",
        "oap_decision",
        "ucp_checkout_session",
        "local_policy"
      ]
    },
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "protocol_hint": {
      "type": "string",
      "description": "Optional informative hint for the concrete source protocol. Verifiers must not infer authority from this field without local policy.",
      "enum": [
        "ap2",
        "ap2_human_not_present",
        "mcp-oauth",
        "oap_aport",
        "openid-connect",
        "spiffe",
        "stripe_spt",
        "ucp",
        "x402"
      ]
    },
    "digest": {
      "type": "object",
      "description": "Portable digest descriptor. The v0.3 AL2 conformance corpus is stricter than this reusable schema and requires sha-256 with a lowercase 64-character hexadecimal value for artifact-backed comparison.",
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "enum": [
            "sha-256",
            "sha-384",
            "sha-512"
          ]
        },
        "value": {
          "type": "string",
          "description": "Digest value. For the v0.3 AL2 conformance corpus, use lowercase SHA-256 hexadecimal.",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": [
        "result",
        "checked_at",
        "method"
      ],
      "properties": {
        "result": {
          "type": "string",
          "enum": [
            "verified",
            "failed",
            "unknown",
            "stale",
            "unavailable"
          ]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "status_result": {
          "type": "string",
          "enum": [
            "active",
            "attenuated",
            "suspended",
            "revoked",
            "quarantined",
            "unknown",
            "not_applicable"
          ]
        },
        "failure_reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
