{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:conformance-corpus:2026-07",
  "title": "VATE Conformance Corpus Index",
  "description": "Language-neutral index for one VATE conformance corpus snapshot.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "name",
    "root",
    "case_schema",
    "summary",
    "digest",
    "cases",
    "manifest"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "vate-conformance-corpus-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "root": {
      "type": "string",
      "minLength": 1
    },
    "case_schema": {
      "type": "string",
      "minLength": 1
    },
    "conformance_report_schema": {
      "type": "string",
      "minLength": 1
    },
    "implementation_report_schema": {
      "type": "string",
      "minLength": 1
    },
    "digest_basis": {
      "type": "object",
      "required": [
        "alg",
        "canonicalization"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "const": "sha-256"
        },
        "canonicalization": {
          "type": "string",
          "minLength": 1
        },
        "manifest_excludes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "case_count",
        "artifact_count"
      ],
      "properties": {
        "case_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "category_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": true
    },
    "digest": {
      "type": "object",
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "const": "sha-256"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "path",
          "category",
          "expected_outcome",
          "expected_should_execute",
          "expected_reason_codes"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "expected_outcome": {
            "type": "string",
            "minLength": 1
          },
          "expected_should_execute": {
            "type": "boolean"
          },
          "expected_reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "validation_focus": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "artifacts": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": true
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
