{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:sut-result:2026-07",
  "title": "VATE SUT Result Set",
  "description": "Machine-readable results emitted by a system under test for one VATE conformance corpus snapshot.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "generated_at",
    "implementation",
    "corpus",
    "results"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "vate-sut-results-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "implementation": {
      "type": "object",
      "required": [
        "name",
        "type",
        "version",
        "language"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "corpus": {
      "type": "object",
      "required": [
        "profile",
        "digest"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "const": "VATE-AL2-Verifier-Admission-v0.2"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "status",
          "outcome",
          "should_execute",
          "reason_codes"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "skipped",
              "error"
            ]
          },
          "outcome": {
            "type": "string",
            "minLength": 1
          },
          "should_execute": {
            "type": "boolean"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "pass"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "pass": {
                  "type": "boolean"
                },
                "details": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "artifacts": {
            "type": "object",
            "description": "Artifact references used to support the reported result for this case.",
            "properties": {
              "admission_receipt": {
                "$ref": "#/$defs/receiptArtifactRef"
              },
              "post_execution_receipt": {
                "$ref": "#/$defs/receiptArtifactRef"
              },
              "verification_context": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/verificationContextRef"
                }
              },
              "proof_artifacts": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/proofArtifactRef"
                }
              }
            },
            "additionalProperties": true
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "object",
      "required": [
        "alg",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "const": "sha-256"
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    },
    "receiptArtifactRef": {
      "type": "object",
      "required": [
        "uri",
        "media_type",
        "digest"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": true
    },
    "verificationContextRef": {
      "type": "object",
      "required": [
        "kind",
        "case_artifact",
        "uri",
        "digest"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "case_artifact": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": true
    },
    "proofArtifactRef": {
      "type": "object",
      "required": [
        "kind",
        "case_artifact",
        "uri",
        "media_type",
        "digest"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "jose_proof_package",
            "jose_detached_payload",
            "jose_trust_bundle"
          ]
        },
        "case_artifact": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
