{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:sut-result:2026-07",
  "title": "VATE SUT Result Set",
  "description": "Machine-readable results emitted by a system under test for one VATE conformance corpus snapshot.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "generated_at",
    "implementation",
    "corpus",
    "results"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "vate-sut-results-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "implementation": {
      "type": "object",
      "required": [
        "name",
        "type",
        "version",
        "language"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "corpus": {
      "type": "object",
      "required": [
        "profile",
        "digest"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "const": "VATE-AL2-Verifier-Admission-v0.2"
        },
        "digest": {
          "type": "object",
          "required": [
            "alg",
            "value"
          ],
          "properties": {
            "alg": {
              "type": "string",
              "const": "sha-256"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "status",
          "outcome",
          "reason_codes"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "skipped",
              "error"
            ]
          },
          "outcome": {
            "type": "string",
            "minLength": 1
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "pass"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "pass": {
                  "type": "boolean"
                },
                "details": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
