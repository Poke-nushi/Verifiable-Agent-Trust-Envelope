{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:app:schema:passport-credential:0.1",
  "title": "Trust Envelope Passport Credential",
  "description": "Draft JSON Schema for the decoded v0.1 Passport Credential (APC) payload in Verifiable Agent Trust Envelope. Packaging such as JWS is transport-level and validated separately.",
  "type": "object",
  "required": [
    "version",
    "passport_id",
    "subject",
    "controller",
    "issuer",
    "assurance_level",
    "capabilities",
    "status_ref",
    "valid_from",
    "valid_until"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "appc-0.1"
    },
    "passport_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "required": [
        "root_id",
        "public_alias"
      ],
      "properties": {
        "root_id": {
          "type": "string",
          "minLength": 1
        },
        "public_alias": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "controller": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "issuer": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "assurance_level": {
      "type": "string",
      "enum": [
        "AL0",
        "AL1",
        "AL2",
        "AL3",
        "AL4"
      ]
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "self_declared": {
          "$ref": "#/$defs/stringArray"
        },
        "verified": {
          "$ref": "#/$defs/stringArray"
        },
        "observed": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "status_ref": {
      "type": "string",
      "format": "uri"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
