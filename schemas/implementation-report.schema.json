{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:implementation-report:2026-07",
  "title": "VATE Implementation Report",
  "description": "Machine-readable report describing one implementation run against one VATE conformance corpus snapshot.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "generated_at",
    "status",
    "implementation",
    "corpus",
    "conformance_report",
    "summary",
    "case_results"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "vate-implementation-report-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "partial",
        "not_applicable"
      ]
    },
    "implementation": {
      "type": "object",
      "required": [
        "name",
        "type",
        "version",
        "language"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "corpus": {
      "type": "object",
      "required": [
        "name",
        "root",
        "case_count",
        "artifact_count",
        "digest"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "root": {
          "type": "string",
          "minLength": 1
        },
        "case_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "digest": {
          "type": "object",
          "required": [
            "alg",
            "value"
          ],
          "properties": {
            "alg": {
              "type": "string",
              "const": "sha-256"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "manifest": {
          "type": "array",
          "description": "Sorted corpus artifact manifest used to compute corpus.digest.",
          "items": {
            "type": "object",
            "required": [
              "path",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "conformance_report": {
      "type": "object",
      "required": [
        "uri",
        "media_type",
        "digest"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "const": "application/vate-conformance-report+json"
        },
        "digest": {
          "type": "object",
          "required": [
            "alg",
            "value"
          ],
          "properties": {
            "alg": {
              "type": "string",
              "const": "sha-256"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "digest_basis": {
          "type": "string",
          "description": "How conformance_report.digest was computed.",
          "enum": [
            "json-sorted-no-whitespace",
            "exact-bytes"
          ]
        }
      },
      "additionalProperties": true
    },
    "publication": {
      "type": "object",
      "description": "Optional publication metadata for a durable implementation report location controlled by the implementer.",
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "controlled_origin": {
          "type": "string",
          "description": "Origin or repository namespace controlled by the implementation maintainer.",
          "minLength": 1
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "immutability": {
          "type": "string",
          "enum": [
            "content_addressed",
            "release_asset",
            "git_commit",
            "versioned_url",
            "mutable_url"
          ]
        }
      },
      "additionalProperties": true
    },
    "proofs": {
      "type": "array",
      "description": "Optional external proof references for the implementation report or its containing release artifact.",
      "items": {
        "type": "object",
        "required": [
          "format",
          "uri"
        ],
        "properties": {
          "format": {
            "type": "string",
            "enum": [
              "detached_jws",
              "signed_git_tag",
              "sigstore_bundle",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "key_ref": {
            "type": "string",
            "minLength": 1
          },
          "covered_artifact": {
            "type": "string",
            "enum": [
              "implementation_report",
              "conformance_report",
              "sut_results",
              "release_bundle"
            ]
          },
          "payload_digest": {
            "type": "object",
            "required": [
              "alg",
              "value"
            ],
            "properties": {
              "alg": {
                "type": "string",
                "const": "sha-256"
              },
              "value": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "passed",
        "failed",
        "skipped"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "case_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "expected_outcome",
          "actual_outcome",
          "pass"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "expected_outcome": {
            "type": "string",
            "minLength": 1
          },
          "actual_outcome": {
            "type": "string",
            "minLength": 1
          },
          "expected_should_execute": {
            "type": "boolean"
          },
          "actual_should_execute": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "pass": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
