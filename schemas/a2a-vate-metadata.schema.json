{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:a2a-metadata:0.2",
  "title": "A2A VATE Metadata Binding",
  "description": "Draft v0.2 metadata object for carrying VATE admission and receipt references in A2A metadata.",
  "type": "object",
  "required": [
    "profile",
    "phase",
    "transaction_id",
    "assurance_level",
    "issuer",
    "issued_at"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "phase": {
      "type": "string",
      "enum": [
        "admission_requested",
        "admission_issued",
        "post_execution_receipt_issued"
      ]
    },
    "transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "assurance_level": {
      "type": "string",
      "const": "AL2"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "attenuate",
        "deny"
      ]
    },
    "admission_request": {
      "$ref": "#/$defs/artifact_reference"
    },
    "admission_receipt": {
      "$ref": "#/$defs/artifact_reference"
    },
    "post_execution_receipt": {
      "$ref": "#/$defs/artifact_reference"
    },
    "policy_snapshot": {
      "description": "Optional digest-bound reference to the verifier policy snapshot used for the admission decision. This is for audit-heavy deployments and does not make policy semantics part of A2A core.",
      "$ref": "#/$defs/artifact_reference"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_reference"
      }
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "description": "Explicit extension area. Unknown data here must not grant authority unless a profile registers and validates it.",
      "type": "object",
      "propertyNames": {
        "type": "string",
        "anyOf": [
          {
            "format": "uri"
          },
          {
            "pattern": "^x_[A-Za-z0-9_.-]+$"
          }
        ]
      },
      "additionalProperties": true
    },
    "annotations": {
      "description": "Non-normative annotations for debugging, logging, or review. These values are not part of the admission authority decision.",
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "const": "admission_requested"
          }
        },
        "required": [
          "phase"
        ]
      },
      "then": {
        "required": [
          "admission_request"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "const": "admission_issued"
          }
        },
        "required": [
          "phase"
        ]
      },
      "then": {
        "required": [
          "admission_receipt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "const": "post_execution_receipt_issued"
          }
        },
        "required": [
          "phase"
        ]
      },
      "then": {
        "required": [
          "admission_receipt",
          "post_execution_receipt"
        ]
      }
    }
  ],
  "$defs": {
    "artifact_reference": {
      "type": "object",
      "required": [
        "type",
        "uri",
        "media_type",
        "digest"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "object",
          "description": "Digest descriptor for A2A metadata references. The v0.2 AL2 metadata profile requires sha-256 with a lowercase 64-character hexadecimal value.",
          "required": [
            "alg",
            "value"
          ],
          "properties": {
            "alg": {
              "type": "string",
              "const": "sha-256"
            },
            "value": {
              "type": "string",
              "description": "Digest value. For the v0.2 AL2 conformance corpus, use lowercase SHA-256 hexadecimal.",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "evidence_reference": {
      "type": "object",
      "required": [
        "type",
        "uri",
        "media_type",
        "digest"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/artifact_reference/properties/digest"
        },
        "signature_profile": {
          "$ref": "#/$defs/signature_profile"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        },
        "annotations": {
          "$ref": "#/$defs/annotations"
        }
      },
      "additionalProperties": false
    },
    "signature_profile": {
      "type": "object",
      "required": [
        "format",
        "canonicalization",
        "required_headers"
      ],
      "properties": {
        "format": {
          "type": "string",
          "minLength": 1
        },
        "canonicalization": {
          "type": "string",
          "minLength": 1
        },
        "required_headers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "anyOf": [
          {
            "format": "uri"
          },
          {
            "pattern": "^x_[A-Za-z0-9_.-]+$"
          }
        ]
      },
      "additionalProperties": true
    },
    "annotations": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
