{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:conformance-report:2026-07",
  "title": "VATE Conformance Report",
  "description": "Machine-readable report emitted by the VATE AL2 conformance runner.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "checked_at",
    "summary",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "vate-conformance-report-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.2"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "passed",
        "failed",
        "skipped"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "category",
          "expected_outcome",
          "actual_outcome",
          "expected_reason_codes",
          "actual_reason_codes",
          "pass"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "expected_outcome": {
            "type": "string",
            "minLength": 1
          },
          "actual_outcome": {
            "type": "string",
            "minLength": 1
          },
          "expected_reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "actual_reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "pass": {
            "type": "boolean"
          },
          "failures": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "fatal_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
