{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:app:schema:attenuation-effect:0.1",
  "title": "Trust Envelope Attenuation Effect",
  "description": "Draft JSON Schema for a machine-readable attenuation effect object in Verifiable Agent Trust Envelope.",
  "type": "object",
  "required": [
    "version",
    "mode",
    "require_new_permit",
    "constraints"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "app-effect-0.1"
    },
    "mode": {
      "type": "string",
      "enum": [
        "narrow"
      ]
    },
    "require_new_permit": {
      "type": "boolean"
    },
    "supersedes": {
      "type": "string",
      "minLength": 1
    },
    "original_request_hash": {
      "type": "string",
      "minLength": 1
    },
    "effective_request_hash": {
      "type": "string",
      "minLength": 1
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "op",
          "path",
          "reason_code"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add",
              "remove",
              "replace"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "source_status_ref": {
            "type": "string",
            "minLength": 1
          },
          "source_evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "max_amount_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_redelegation_depth": {
          "type": "integer",
          "minimum": 0
        },
        "tool_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "minLength": 1
            },
            "policy_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "effective_constraints": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
