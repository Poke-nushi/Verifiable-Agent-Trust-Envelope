{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:app:schema:attenuation-effect:0.2",
  "title": "Trust Envelope Attenuation Effect",
  "description": "Draft JSON Schema for a canonical machine-readable attenuation effect object in Verifiable Agent Trust Envelope. This schema describes normalized AL2 emission shape; status-layer or legacy input aliases such as max_amount_usd are input signals that must be normalized before receipt emission.",
  "type": "object",
  "required": [
    "version",
    "mode",
    "require_new_permit",
    "constraints"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "app-effect-0.2"
    },
    "mode": {
      "type": "string",
      "enum": [
        "narrow"
      ]
    },
    "require_new_permit": {
      "type": "boolean"
    },
    "supersedes": {
      "type": "string",
      "minLength": 1
    },
    "original_request_hash": {
      "type": "string",
      "minLength": 1
    },
    "effective_request_hash": {
      "type": "string",
      "minLength": 1
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "op",
          "path",
          "reason_code"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add",
              "remove",
              "replace"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "source_status_ref": {
            "type": "string",
            "minLength": 1
          },
          "source_evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "constraints": {
      "type": "object",
      "description": "Canonical constraints carried by app-effect-0.2. Admission receipts use attenuation.effective_constraints instead.",
      "minProperties": 1,
      "properties": {
        "target_resource": {
          "type": "string",
          "minLength": 1
        },
        "max_amount": {
          "$ref": "#/$defs/moneyAmount"
        },
        "max_redelegation_depth": {
          "type": "integer",
          "minimum": 0
        },
        "tool_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "minLength": 1
            },
            "policy_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "not": {
        "anyOf": [
          {
            "required": [
              "max_amount_usd"
            ]
          },
          {
            "required": [
              "resource"
            ]
          }
        ]
      },
      "additionalProperties": true
    }
  },
  "not": {
    "required": [
      "effective_constraints"
    ]
  },
  "$defs": {
    "moneyAmount": {
      "type": "object",
      "required": [
        "currency",
        "value"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "value": {
          "description": "Review artifacts SHOULD emit a canonical decimal string. JSON numbers are accepted only for input compatibility and must be normalized before stable receipt emission.",
          "anyOf": [
            {
              "type": "string",
              "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
            },
            {
              "type": "number",
              "minimum": 0
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "approvalConstraint": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "policy_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
