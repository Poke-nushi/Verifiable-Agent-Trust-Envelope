{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vate:schema:evidence-vocabulary:2026-07",
  "title": "VATE Evidence Vocabulary Registry",
  "description": "Machine-readable evidence type and protocol hint registry for the VATE AL2 verifier admission conformance profile.",
  "type": "object",
  "required": [
    "version",
    "profile",
    "evidence_types",
    "protocol_hints"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "const": "vate-evidence-vocabulary-2026-07"
    },
    "profile": {
      "type": "string",
      "const": "VATE-AL2-Verifier-Admission-v0.3"
    },
    "evidence_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "description",
          "allowed_protocol_hints"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "allowed_protocol_hints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "protocol_hints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
