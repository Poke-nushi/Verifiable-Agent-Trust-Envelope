        "expected": "present"
      },
      {
        "name": "a2a_metadata.policy_snapshot.digest",
        "expected": "present"
      }
    ]
  },
  "validation_focus": [
    "attenuate decision",
    "machine-readable attenuation",
    "digest-bound A2A receipt reference",
